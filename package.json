{
	"name": "lms-repo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.12.9",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"motion": "^12.38.0",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18",
			"typescript": "^5.9.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"start:server": "turbo -F server start",
		"start:web": "turbo -F web serve",
		"db:push": "turbo -F @lms-repo/db db:push",
		"db:studio": "turbo -F @lms-repo/db db:studio",
		"db:generate": "turbo -F @lms-repo/db db:generate",
		"db:migrate": "turbo -F @lms-repo/db db:migrate",
		"db:seed": "turbo -F @lms-repo/db db:seed",
		"docker:up": "docker-compose -f docker/docker-compose.dev.yml up -d",
		"docker:build": "docker-compose -f docker/docker-compose.dev.yml build",
		"docker:logs": "docker-compose -f docker/docker-compose.dev.yml logs",
		"docker:down": "docker-compose -f docker/docker-compose.dev.yml down",
		"docker:restart": "docker-compose -f docker/docker-compose.dev.yml restart",
		"docker:exec:web": "docker-compose -f docker/docker-compose.dev.yml exec web /bin/bash",
		"docker:exec:server": "docker-compose -f docker/docker-compose.dev.yml exec server /bin/bash",
		"email:dev": "turbo -F @lms-repo/emails email:dev",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@lms-repo/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@lms-repo/config": "workspace:*",
		"@types/bun": "catalog:",
		"turbo": "^2.9.3",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.11"
}
